# --- Entorno ---
ENV=development

# --- PostgreSQL ---
POSTGRES_USER=ceibal
POSTGRES_PASSWORD=ceibal_dev_pass

# Usado por el backend corriendo LOCAL (fuera de Docker):
DATABASE_URL=postgresql://ceibal:ceibal_dev_pass@localhost:5432/ceibal_dev

# --- CORS ---
# Con Docker Compose: http://localhost,http://localhost:80
# Desarrollo local (npm run dev): http://localhost:5173
CORS_ORIGINS=http://localhost:5173

# --- AWS Cognito ---
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_APP_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# --- AI Gateway (Ceibal) ---
GATEWAY_AI_URL=http://your-gateway-url/gateway-ai
GATEWAY_FILE_URL=http://your-gateway-url/process

# --- OpenRouter (pipelines de feedback) ---
OPENROUTER_API_KEY=sk-or-v1-change-me
AUDIO_MODEL=xiaomi/mimo-v2-omni
HANDWRITE_MODEL=google/gemini-3.1-flash-lite-preview

# --- AWS S3 ---
AWS_REGION=us-east-1
S3_BUCKET_HANDWRITE=ceibal-gateway-file-uploads-dev

# --- Frontend (Docker build args) ---
# URL de la API visible desde el browser
VITE_API_URL=http://localhost:8000
# Mismo User Pool ID que arriba
VITE_COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
# Mismo App Client ID que arriba
VITE_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
