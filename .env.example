# Environment: development | production
ENV=development

# JWT — mínimo 32 caracteres, mantenerlo secreto
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars
JWT_EXPIRE_HOURS=24

# PostgreSQL
POSTGRES_USER=ceibal
POSTGRES_PASSWORD=ceibal_dev_pass
DATABASE_URL=postgresql://ceibal:ceibal_dev_pass@localhost:5432/ceibal_dev

# CORS — orígenes permitidos separados por coma
CORS_ORIGINS=http://localhost:5173
