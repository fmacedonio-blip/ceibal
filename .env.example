# ─── Entorno ────────────────────────────────────────────────────────────────
# development habilita /auth/dev-login y el selector de rol en el login
ENV=development

# ─── JWT ────────────────────────────────────────────────────────────────────
# Mínimo 32 caracteres. Podés generar uno con:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars
JWT_EXPIRE_HOURS=24

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_USER=ceibal
POSTGRES_PASSWORD=ceibal_dev_pass

# Usado por el backend corriendo LOCAL (fuera de Docker):
DATABASE_URL=postgresql://ceibal:ceibal_dev_pass@localhost:5432/ceibal_dev

# ─── CORS ────────────────────────────────────────────────────────────────────
# Con Docker Compose: http://localhost,http://localhost:80
# Desarrollo local (npm run dev): http://localhost:5173
CORS_ORIGINS=http://localhost:5173

# ─── AI Gateway (Ceibal) ─────────────────────────────────────────────────────
# Endpoint del AI Gateway de Ceibal (no requiere API key)
GATEWAY_AI_URL=http://k8s-ceibalpublicalb-0698fcf46b-1484417591.us-east-1.elb.amazonaws.com/gateway-ai

# ─── OpenRouter (pipelines de feedback) ─────────────────────────────────────
# Obtené tu API key en https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-change-me
# Modelo para análisis de audio (requiere soporte de audio)
AUDIO_MODEL=xiaomi/mimo-v2-omni
# Modelo para análisis de escritura manuscrita (requiere visión)
HANDWRITE_MODEL=google/gemini-3.1-flash-lite-preview

# ─── Frontend ────────────────────────────────────────────────────────────────
# URL de la API que usa el frontend al compilar con Docker.
# Con Docker Compose dejar en http://localhost:8000.
VITE_API_URL=http://localhost:8000
